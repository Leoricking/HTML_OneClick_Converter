{
  "manifest_version": 3,
  "name": "HTML 一鍵轉圖片／純文字",
  "version": "1.2.0",
  "description": "一鍵將目前網頁儲存為 PNG/JPG、整頁長截圖、PDF、純文字，或複製內容到 OneNote。",
  "minimum_chrome_version": "109",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "action": {
    "default_title": "HTML 一鍵轉換器",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}